# Supabase (database only — auth is handled by Firebase)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Firebase (authentication)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here

# Razorpay (server-side only — never expose to client)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# CORS — comma-separated list of allowed frontend origins for payment endpoints
# Example: https://takshak.ed,https://www.takshak.ed
ALLOWED_ORIGINS=https://your-production-domain.com

# Supabase Service Role (seed scripts only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
